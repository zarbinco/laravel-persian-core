{
    "name": "zarbinco/laravel-persian-core",
    "description": "Persian text and number normalization utilities for Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.10|^2.0",
        "larastan/larastan": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Zarbinco\\PersianCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zarbinco\\PersianCore\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zarbinco\\PersianCore\\PersianCoreServiceProvider"
            ],
            "aliases": {
                "Persian": "Zarbinco\\PersianCore\\Facades\\Persian"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format": "pint",
        "lint": [
            "composer validate --strict",
            "phpstan analyse",
            "phpunit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
